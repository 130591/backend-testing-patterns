# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=backend_testing

# Server
PORT=3000

# JWT
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRES_IN=8h

# SMTP (MailHog local)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@medicalapp.com

# Twilio (optional - logs to console if not set)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# FHIR
FHIR_BASE_URL=http://localhost:8080/fhir

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
